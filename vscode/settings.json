    //     "org.junit.jupiter.api.DynamicContainer.*",
    //     "org.junit.jupiter.api.DynamicTest.*",
    //     "org.mockito.Mockito.*",
    //     "org.mockito.ArgumentMatchers.*",
    //     "org.mockito.Answers.*"
    // ],
    // "java.debug.settings.hotCodeReplace": "auto",
    // "redhat.telemetry.enabled": true,

    // jsonの設定
    "json.format.keepLines": true,

    // powerShellの設定
    "powershell.powerShellAdditionalExePaths": {
        "exePath": "C:\\Program Files\\PowerShell\\8\\pwsh.exe",
        "version": "7",
        "versionName": "PowerShell 7"
    },
    "powershell.powerShellDefaultVersion": "7.5.4",
    "prettier.printWidth": 128,
    "python.defaultInterpreterPath": "C:\\Users\\c17h2\\scoop\\shims\\python3.exe",
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.integrated.defaultProfile.windows": "PowerShell",

    // ターミナルの設定
    "terminal.integrated.fontFamily": "HackGen Console NF",
    "terminal.integrated.fontSize": 16,
    // ターミナルのスクロールバックをたくさんできるようにする
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.profiles.windows": {
        "Command Prompt": {
            "args": [ ],
            "icon": "terminal-cmd",
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ]
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "PowerShell": {
            "icon": "terminal-powershell",
            "source": "PowerShell"
        }
    },
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "workbench.startupEditor": "none",
    "security.allowedUNCHosts": [
        "wsl.localhost"
    ],
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "window.customTitleBarVisibility": "windowed",
    "editor.minimap.enabled": false,

    // SQL Formatterの設定
    "SQL-Formatter-VSCode.dataTypeCase": "upper",
    "SQL-Formatter-VSCode.expressionWidth": 120,
    "SQL-Formatter-VSCode.keywordCase": "upper",
    "workbench.iconTheme": "material-icon-theme",
    // "extensions.experimental.affinity": {
    //     "asvetliakov.vscode-neovim": 1
    // },
    "github.copilot.nextEditSuggestions.enabled": true,
    "powershell.suppressAdditionalExeNotFoundWarning": true,
    "c-cpp-flylint.flexelint.enable": false,
    "c-cpp-flylint.flawfinder.enable": false,
    "c-cpp-flylint.lizard.enable": false,
    "C_Cpp.intelliSenseEngine": "disabled",
    "c-cpp-flylint.clang.enable": false,
    "c-cpp-flylint.clang.warnings": [
        "all",
        "extra"
    ],
    "c-cpp-flylint.clang.includePaths": [
        "C:\\Users\\C17H2\\scoop\\apps\\gcc\\current\\include",
        "C:\\Users\\C17H2\\scoop\\apps\\llvm\\20.1.8\\lib\\clang\\20\\include",
        "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\VC\\Tools\\MSVC\\14.44.35207\\include",
        "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\ucrt",
        "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\shared",
        "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\um",
        "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\winrt",
        "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\cppwinrt"
    ],
    "prettier.tabWidth": 4,
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "workbench.colorTheme": "Noctis Lux",
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [ "comment", "punctuation.definition.comment" ],
                "settings": {
                    "foreground": "#708585",
                    "fontStyle": "normal"
                }
            }
        ]
    },

    // Emacsキーバインドをターミナルでも有効に使いたい
    "terminal.integrated.allowChords": false,
    "terminal.integrated.commandsToSkipShell": [
        "-workbench.action.toggleSidebarVisibility",
        "-workbench.action.terminal.focusFind",
        "-workbench.action.quickOpen",
        "-workbench.action.quickOpenNavigateNextInFilePicker",
        "-editor.action.toggleTabFocusMode"
    ],

    "editor.lineNumbers": "relative",

    // insertモード時にctrl+<key>をNeoVim側に送信したいものだけを指定
    "vscode-neovim.ctrlKeysForInsertMode": [
        "a",
        "e",
        "b",
        "f",
        "n",
        "p",
        "l" // Recenter Top Bottom
    ],
    // normalモード時にctrl+<key>をNeoVim側に送信したいものだけを指定
    "vscode-neovim.ctrlKeysForNormalMode": [
        "a", // 数字を1増やす
        "d", // 画面半分下にスクロール
        "e", // カーソルを移動せず画面を下にスクロール
        "g", // ESC
        "l", // Recenter Top Bottom
        "m", // enter
        // "o", // 前の場所に戻る(keybindings.jsonで設定)
        "r", // Redo
        // "t", // 元の場所に戻る(keybindings.jsonで設定)
        "u", // 画面半分上にスクロール
        "v", // 矩形選択
        "w", // ウィンドウ操作
        "x", // decrement
        "y", // カーソルを移動せず画面を上にスクロール
        "/", // コメントアウト
        "]" // 定義ジャンプ
    ],
    // Which Key
    "whichkey.delay": 200,
    "whichkey.showIcons": true,
    "whichkey.sortOrder": "none",
    "whichkey.bindings": [
        // ══════════════════════════════════════════
        // トップレベル（単キー）— LazyVimの並び順準拠
        // ══════════════════════════════════════════
        { "key": " ", "name": "󰈞 Find Files (Root Dir)", "type": "command", "command": "workbench.action.quickOpen" },
        { "key": ",", "name": " Buffers", "type": "command", "command": "workbench.action.showAllEditors" },
        { "key": "/", "name": " Grep (Root Dir)", "type": "command", "command": "workbench.action.findInFiles" },
        { "key": ":", "name": " Command History", "type": "command", "command": "workbench.action.showCommands" },
        { "key": "`", "name": "󰘵 Switch to Other Buffer", "type": "command", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup" },
        { "key": ".", "name": "󰓩 Toggle Scratch Buffer", "type": "command", "command": "workbench.action.files.newUntitledFile" },
        { "key": "-", "name": "󰇜 Split Window Below", "type": "command", "command": "workbench.action.splitEditorDown" },
        { "key": "|", "name": "󰇝 Split Window Right", "type": "command", "command": "workbench.action.splitEditor" },
        { "key": "?", "name": "󰌌 Show All Keybindings", "type": "command", "command": "workbench.action.openGlobalKeybindings" },
        { "key": "K", "name": "󰋼 Hover (Keywordprg)", "type": "command", "command": "editor.action.showHover" },
        { "key": "L", "name": "󰋗 Release Notes", "type": "command", "command": "update.showCurrentReleaseNotes" },
        { "key": "l", "name": "󰒲 Extensions (Lazy)", "type": "command", "command": "workbench.view.extensions" },
        { "key": "n", "name": "󰍡 Notification History", "type": "command", "command": "notifications.showList" },
        { "key": "S", "name": "󰷈 Select Scratch Buffer", "type": "command", "command": "workbench.action.showAllEditors" },

        // ══════════════════════════════════════════
        // <leader>b — 󰓩 Buffer
        // ══════════════════════════════════════════
        {
            "key": "b",
            "name": "󰓩 Buffer",
            "type": "bindings",
            "bindings": [
                { "key": "b", "name": "󰘵 Switch to Other Buffer", "type": "command", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup" },
                { "key": "d", "name": "󰅖 Delete Buffer", "type": "command", "command": "workbench.action.closeActiveEditor" },
                { "key": "D", "name": "󰅗 Delete Buffer and Window", "type": "command", "command": "workbench.action.closeEditorsAndGroup" },
                { "key": "j", "name": "󰒋 Pick Buffer", "type": "command", "command": "workbench.action.showAllEditors" },
                { "key": "l", "name": "󰁍 Delete Buffers to the Left", "type": "command", "command": "workbench.action.closeEditorsToTheLeft" },
                { "key": "o", "name": "󰱝 Delete Other Buffers", "type": "command", "command": "workbench.action.closeOtherEditors" },
                { "key": "p", "name": "󰐃 Toggle Pin", "type": "command", "command": "workbench.action.pinEditor" },
                { "key": "P", "name": "󰐄 Delete Non-Pinned Buffers", "type": "command", "command": "workbench.action.closeOtherEditors" },
                { "key": "r", "name": "󰁎 Delete Buffers to the Right", "type": "command", "command": "workbench.action.closeEditorsToTheRight" }
            ]
        },

        // ══════════════════════════════════════════
        // <leader>c — 󰅩 Code
        // ══════════════════════════════════════════
        {
            "key": "c",
            "name": "󰅩 Code",
            "type": "bindings",
            "bindings": [
                { "key": "a", "name": "󰛩 Code Action", "type": "command", "command": "editor.action.quickFix" },
                { "key": "A", "name": "󰃤 Source Action", "type": "command", "command": "editor.action.sourceAction" },
                { "key": "c", "name": "󰗊 Run Codelens", "type": "command", "command": "codelens.showLensesInCurrentLine" },
                { "key": "C", "name": "󰑐 Refresh Codelens", "type": "command", "command": "codelens.showLensesInCurrentLine" },
                { "key": "d", "name": "󰙨 Line Diagnostics", "type": "command", "command": "editor.action.showHover" },
                { "key": "f", "name": "󰉢 Format Document", "type": "command", "command": "editor.action.formatDocument" },
                { "key": "F", "name": "󰉣 Format Injected Langs", "type": "command", "command": "editor.action.formatDocument" },
                { "key": "l", "name": "󰒋 LSP Info", "type": "command", "command": "workbench.action.showAllSymbols" },
                { "key": "m", "name": "󰏗 Mason → Extensions", "type": "command", "command": "workbench.view.extensions" },
                { "key": "o", "name": "󰶘 Organize Imports", "type": "command", "command": "editor.action.organizeImports" },
                { "key": "r", "name": "󰑕 Rename Symbol", "type": "command", "command": "editor.action.rename" },
                { "key": "R", "name": "󰲏 Rename File", "type": "command", "command": "workbench.files.action.showActiveFileInExplorer" },
                { "key": "s", "name": "󰜬 Symbols (Outline)", "type": "command", "command": "outline.focus" },
                { "key": "S", "name": "󰌷 LSP References", "type": "command", "command": "references-view.find" }
            ]
        },

        // ══════════════════════════════════════════
        // <leader>d —  Debug / Profiler
        // ══════════════════════════════════════════
        {
            "key": "d",
            "name": " Debug",
            "type": "bindings",
            "bindings": [
                {
                    "key": "p",
                    "name": "󰙨 Profiler",
                    "type": "bindings",
                    "bindings": [
                        { "key": "h", "name": "󰌁 Profiler Highlights", "type": "command", "command": "workbench.action.toggleDevTools" },
                        { "key": "p", "name": "󰙨 Toggle Profiler", "type": "command", "command": "workbench.action.toggleDevTools" },
                        { "key": "s", "name": "󰓩 Profiler Scratch Buffer", "type": "command", "command": "workbench.action.files.newUntitledFile" }
                    ]
                }
            ]
        },

        // ══════════════════════════════════════════
        // <leader>f — 󰈞 File / Find
        // ══════════════════════════════════════════
        {
            "key": "f",
            "name": "󰈞 File / Find",
            "type": "bindings",
            "bindings": [
                { "key": "b", "name": "󰓩 Buffers", "type": "command", "command": "workbench.action.showAllEditors" },
                { "key": "B", "name": "󰓩 Buffers (all)", "type": "command", "command": "workbench.action.showAllEditors" },
                { "key": "c", "name": " Find Config File", "type": "command", "command": "workbench.action.openSettingsJson" },
                { "key": "f", "name": "󰈞 Find Files (Root Dir)", "type": "command", "command": "workbench.action.quickOpen" },
                { "key": "F", "name": "󰈞 Find Files (cwd)", "type": "command", "command": "workbench.action.quickOpen" },
                { "key": "g", "name": " Find Files (git-files)", "type": "command", "command": "workbench.action.quickOpen" },
                { "key": "n", "name": "󰎔 New File", "type": "command", "command": "workbench.action.files.newUntitledFile" },
                { "key": "p", "name": "󰏗 Projects", "type": "command", "command": "workbench.action.openRecent" },
                { "key": "r", "name": "󰣜 Recent Files", "type": "command", "command": "workbench.action.openRecent" },
                { "key": "R", "name": "󰣜 Recent Files (cwd)", "type": "command", "command": "workbench.action.openRecent" },
                { "key": "t", "name": " Terminal (Root Dir)", "type": "command", "command": "workbench.action.terminal.toggleTerminal" },
                { "key": "T", "name": " Terminal (cwd)", "type": "command", "command": "workbench.action.terminal.new" }
            ]
        },

        // ══════════════════════════════════════════
        // <leader>g —  Git
        // ══════════════════════════════════════════
        {
            "key": "g",
            "name": " Git",
            "type": "bindings",
            "bindings": [
                { "key": "b", "name": "󰊢 Git Blame Line", "type": "command", "command": "gitlens.toggleLineBlame" },
                { "key": "B", "name": "󰖟 Git Browse (open)", "type": "command", "command": "gitlens.openFileOnRemote" },
                { "key": "d", "name": " Git Diff (hunks)", "type": "command", "command": "workbench.view.scm" },
                { "key": "D", "name": " Git Diff (origin)", "type": "command", "command": "gitlens.diffWithRevision" },
                { "key": "f", "name": "󰋚 Git File History", "type": "command", "command": "gitlens.showQuickFileHistory" },
                { "key": "g", "name": "󰊢 Source Control", "type": "command", "command": "workbench.view.scm" },
                { "key": "G", "name": "󰜘 Git Graph", "type": "command", "command": "gitlens.showGraphPage" },
                {
                    "key": "h",
                    "name": "󰊢 Hunks",
                    "type": "bindings",
                    "bindings": [
                        { "key": "b", "name": "󰊢 Blame Line (full)", "type": "command", "command": "gitlens.toggleLineBlame" },
                        { "key": "B", "name": "󰊢 Blame Buffer", "type": "command", "command": "gitlens.toggleFileBlame" },
                        { "key": "d", "name": " Diff This", "type": "command", "command": "git.openChange" },
                        { "key": "D", "name": " Diff This ~", "type": "command", "command": "gitlens.diffWithRevision" },
                        { "key": "p", "name": "󰍉 Preview Hunk Inline", "type": "command", "command": "editor.action.dirtydiff.next" },
                        { "key": "r", "name": "󰜺 Reset Hunk", "type": "command", "command": "git.revertSelectedRanges" },
                        { "key": "R", "name": "󰜺 Reset Buffer", "type": "command", "command": "git.clean" },
                        { "key": "s", "name": "󰐕 Stage Hunk", "type": "command", "command": "git.stageSelectedRanges" },
                        { "key": "S", "name": "󰐕 Stage Buffer", "type": "command", "command": "git.stage" },
                        { "key": "u", "name": "󰕌 Undo Stage Hunk", "type": "command", "command": "git.unstageSelectedRanges" }
                    ]
                },
                { "key": "i", "name": " GitHub Issues (open)", "type": "command", "command": "issues.issuesView.focus" },
                { "key": "I", "name": " GitHub Issues (all)", "type": "command", "command": "issues.issuesView.focus" },
                { "key": "l", "name": "󰋚 Git Log", "type": "command", "command": "gitlens.showGraphPage" },
                { "key": "L", "name": "󰋚 Git Log (cwd)", "type": "command", "command": "git.viewHistory" },
                { "key": "p", "name": " GitHub PRs (open)", "type": "command", "command": "pr.focus" },
                { "key": "P", "name": " GitHub PRs (all)", "type": "command", "command": "pr.focus" },
                { "key": "s", "name": "󰐗 Git Status", "type": "command", "command": "workbench.view.scm" },
                { "key": "S", "name": "󰆓 Git Stash", "type": "command", "command": "git.stash" },
                { "key": "Y", "name": "󰆏 Git Browse (copy URL)", "type": "command", "command": "gitlens.copyRemoteFileUrl" }
            ]
        },

        // ══════════════════════════════════════════
        // <leader>q — 󰗼 Quit / Session
        // ══════════════════════════════════════════
        {
            "key": "q",
            "name": "󰗼 Quit / Session",
            "type": "bindings",
            "bindings": [
                { "key": "d", "name": "󰅗 Don't Save Session", "type": "command", "command": "workbench.action.closeWindow" },
                { "key": "l", "name": "󰦛 Restore Last Session", "type": "command", "command": "workbench.action.openRecent" },
                { "key": "q", "name": "󰗼 Quit All", "type": "command", "command": "workbench.action.closeWindow" },
                { "key": "s", "name": "󰑓 Restore Session", "type": "command", "command": "workbench.action.openRecent" },
