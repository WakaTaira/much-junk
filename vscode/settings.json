    "settings.cycle": [
        {
            "id": "lineNumbers",
            "overrideWorkspaceSettings": true,
            "values": [
                { "editor.lineNumbers": "on" },
                { "editor.lineNumbers": "off" }
            ]
        },
        {
            "id": "relativeLineNumbers",
            "overrideWorkspaceSettings": true,
            "values": [
                { "editor.lineNumbers": "on" },
                { "editor.lineNumbers": "relative" }
            ]
        },
        {
            "id": "smoothScrolling",
            "overrideWorkspaceSettings": true,
            "values": [
                { "editor.smoothScrolling": true, "workbench.list.smoothScrolling": true },
                { "editor.smoothScrolling": false, "workbench.list.smoothScrolling": false }
            ]
        },
        {
            "id": "cursorAnimation",
            "overrideWorkspaceSettings": true,
            "values": [
                { "editor.cursorBlinking": "smooth", "editor.cursorSmoothCaretAnimation": "on" },
                { "editor.cursorBlinking": "blink", "editor.cursorSmoothCaretAnimation": "off" }
            ]
        }
    ],
    // nvimのパフォーマンスが上がるらしい
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },

