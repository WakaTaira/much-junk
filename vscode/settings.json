{
    // 言語ごとの設定
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    // "[java]": {
    //     "editor.defaultFormatter": "redhat.java"
    // },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[plaintext]": {
        "editor.guides.indentation": false
    },
    "[ruby]": {
        "editor.defaultFormatter": "mbessey.vscode-rufo"
    },

    // blank-formatterの設定
    "black-formatter.args": [
    ],

    // セーブ時の設定
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },

    // フォントの設定
    "editor.fontFamily": "HackGen Console NF",
    "editor.fontSize": 16,
    "vscode_custom_css.imports": [
        // "file:///C:/Users/C17H2/scoop/apps/vscode/current/data/extensions/webrender.synthwave-x-fluoromachine-0.0.14/synthwave-x-fluoromachine.css",
        "file:///C:/Users/C17H2/.config/vscode_custom_files/vscode-whichkey-font.css"
    ],

    // エディタ全般の設定
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.indentSize": "tabSize",
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.wordWrap": "on", // 右端で折り返す
    "editor.cursorBlinking": "phase",
    "editor.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    // 保存時に行末の空白など不要な空白を削除する
    "files.trimTrailingWhitespace": true,

    // htmlテンプレートの設定
    "emmet.includeLanguages": {
        "javascript": "html",
        "plaintext": "html",
        "typescript": "html",
        "vue-html": "html"
    },
    "emmet.syntaxProfiles": {
        "javascript": "jsx",
        "typescript": "tsx",
        "vue-html": "html"
    },
    "emmet.variables": {
        "charset": "UTF-8",
        "lang": "ja"
    },
    "explorer.confirmDelete": false,
    "extensions.autoUpdate": true,
    "files.exclude": {
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.project": true,
        "**/.settings": true
    },

    // なんかあった
    "files.watcherExclude": {
        "**/target/**": true
    },

    // gitの設定
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "never",
    "github.gitProtocol": "ssh",
    // GitHub Copilot
    // デフォルトでオフになっている言語も補完を効かせるようにする
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true,
        "python": true
    },
    // GitHub Copilot Chat
    // 日本語で応答してもらう
    "github.copilot.chat.localeOverride": "ja",
    // OSSなどでコミットメッセージを英語で生成するのに便利
    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "text": "Use a maximum of 120 characters."
        },
        {
            "text": "Messages should be in English."
        }
    ],

    // htmlのフォーマットの設定
    "html.format.contentUnformatted": "script,style", //scriptとstyleタグの中はフォーマットしない
    "html.format.enable": true,
    "html.format.extraLiners": "",
    "html.format.wrapLineLength": 0,
    "html.format.preserveNewLines": false,

    //インデントの色を設定
    "workbench.colorCustomizations": {
        // "editorIndentGuide.background1": "#2250b2",
        // "editorIndentGuide.background2": "#b461b0",
        // "editorIndentGuide.background3": "#00ffff",
        // "editorIndentGuide.background4": "#228b22",
        // "editorIndentGuide.background5": "#cfc100",
        // "editorIndentGuide.background6": "#8b0000",
        // "editorIndentGuide.activeBackground1": "#ffffffaa",
        // "editorIndentGuide.activeBackground2": "#ffffffaa",
        // "editorIndentGuide.activeBackground3": "#ffffffaa",
        // "editorIndentGuide.activeBackground4": "#ffffffaa",
        // "editorIndentGuide.activeBackground5": "#ffffffaa",
        // "editorIndentGuide.activeBackground6": "#ffffffaa",
        // "editor.lineHighlightBackground": "#2D2C57",
        // "tab.activeForeground": "#20b9dd", // アクティブタブの文字色の変更
        // "tab.inactiveForeground": "#ffffff" // 非アクティブタブの文字色の変更
    },

    // javaの設定
    // "java.autobuild.enabled": true,
    // "java.compile.nullAnalysis.mode": "automatic",
    // "java.completion.importOrder": [
