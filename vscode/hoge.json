[
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // WhichKey起動 — Space (vscode-neovim)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "space", "command": "whichkey.show", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "space", "command": "whichkey.show", "when": "editorTextFocus && neovim.mode == visual" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Buffer移動 — S-h / S-l / [b / ]b / [B / ]B
  // keymaps.lua + ui.lua (bufferline)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "shift+h", "command": "workbench.action.previousEditor", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "shift+l", "command": "workbench.action.nextEditor", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[b", "command": "workbench.action.previousEditor", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "]b", "command": "workbench.action.nextEditor", "when": "editorTextFocus && neovim.mode == normal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Window移動 — Ctrl+hjkl
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "ctrl+h", "command": "workbench.action.focusLeftGroup", "when": "editorTextFocus" },
  { "key": "ctrl+j", "command": "workbench.action.focusBelowGroup", "when": "editorTextFocus" },
  { "key": "ctrl+k", "command": "workbench.action.focusAboveGroup", "when": "editorTextFocus" },
  { "key": "ctrl+l", "command": "workbench.action.focusRightGroup", "when": "editorTextFocus" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Windowリサイズ — Ctrl+Arrow
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "ctrl+up", "command": "workbench.action.increaseViewHeight", "when": "editorTextFocus" },
  { "key": "ctrl+down", "command": "workbench.action.decreaseViewHeight", "when": "editorTextFocus" },
  { "key": "ctrl+left", "command": "workbench.action.decreaseViewWidth", "when": "editorTextFocus" },
  { "key": "ctrl+right", "command": "workbench.action.increaseViewWidth", "when": "editorTextFocus" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // 行移動 — Alt+j / Alt+k
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "alt+j", "command": "editor.action.moveLinesDownAction", "when": "editorTextFocus" },
  { "key": "alt+k", "command": "editor.action.moveLinesUpAction", "when": "editorTextFocus" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // 保存 — Ctrl+s
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "ctrl+s", "command": "workbench.action.files.save" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ターミナル — Ctrl+/
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "ctrl+/", "command": "workbench.action.terminal.toggleTerminal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Diagnostic移動 — ]d / [d / ]e / [e / ]w / [w
  // keymaps.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "]d", "command": "editor.action.marker.next", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[d", "command": "editor.action.marker.prev", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "]e", "command": "editor.action.marker.nextInFiles", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[e", "command": "editor.action.marker.prevInFiles", "when": "editorTextFocus && neovim.mode == normal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Quickfix / Trouble移動 — ]q / [q
  // editor.lua (trouble)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "]q", "command": "editor.action.marker.next", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[q", "command": "editor.action.marker.prev", "when": "editorTextFocus && neovim.mode == normal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Hunk移動 — ]h / [h / ]H / [H
  // editor.lua (gitsigns)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "]h", "command": "workbench.action.editor.nextChange", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[h", "command": "workbench.action.editor.previousChange", "when": "editorTextFocus && neovim.mode == normal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Todo移動 — ]t / [t
  // editor.lua (todo-comments)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "]t", "command": "todo-tree.goToNext", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[t", "command": "todo-tree.goToPrevious", "when": "editorTextFocus && neovim.mode == normal" },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // Treesitter textobjects移動 — ]f/[f / ]c/[c / ]a/[a
  // treesitter.lua
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  { "key": "]f", "command": "editor.action.nextSymbolOccurence", "when": "editorTextFocus && neovim.mode == normal" },
  { "key": "[f", "command": "editor.action.previousSymbolOccurence", "when": "editorTextFocus && neovim.mode == normal" }
]